# Soccho Environment Variables (copy to .env and fill real values)
# Shared
AES_SECRET_KEY=your_32_byte_aes_key_hex_here  # e.g. from secrets.token_bytes(32).hex()
DATABASE_URL=postgresql://user:pass@host/db  
REDIS_URL=redis://red-d7p3u6q8qa3s73etvrqg:6379  # Provided

# Gateway (FastAPI)
GATEWAY_SECRET_KEY=your_gateway_secret_here
AUTH_GRPC_HOST=soccho-auth:8001
SOCIAL_GRPC_HOST=soccho-social:8002
TRANSACTION_GRPC_HOST=soccho-transaction:8003
NOTIFICATION_GRPC_HOST=soccho-notification:8004
ALLOWED_ORIGINS=https://soccho.vercel.app,http://localhost:3000

# Auth Service
AUTH_SECRET_KEY=your_auth_secret_here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=$(GOOGLE_CLIENT_ID)
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=$(GOOGLE_CLIENT_SECRET)

# Social Service
SOCIAL_SECRET_KEY=your_social_secret_here

# Transaction Service
TRANSACTION_SECRET_KEY=your_transaction_secret_here

# Notification Service
NOTIFICATION_SECRET_KEY=your_notification_secret_here

# Admin Service
ADMIN_SECRET_KEY=your_admin_secret_here

# Notes
# - Generate secrets: python -c \"import secrets; print('AES_SECRET_KEY=' + secrets.token_bytes(32).hex()); print('KEY=' + secrets.token_urlsafe(50))\"
# - Render auto-injects DB/Redis; override for local
# - Gmail app password for SMTP (not regular password)

